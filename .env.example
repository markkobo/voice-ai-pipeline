# ===========================================
# Voice AI Pipeline - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit .env with real keys to git

# ===========================================
# API Keys
# ===========================================

# MiniMax API Key - used for speech recognition (ASR)
# Get from: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here

# Telegram Bot Token - for Telegram bot notifications (optional)
# Get from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key - used for LLM responses
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model - model to use for LLM
OPENAI_MODEL=gpt-4o-mini

# OpenAI Base URL - API endpoint (change for proxies/custom endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1

# HuggingFace Token - for gated models (Qwen3-TTS, etc.)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ===========================================
# Paths & Storage
# ===========================================

# HuggingFace cache directory - where models are downloaded
HF_HOME=/workspace/voice-ai-pipeline/.cache/huggingface

# ===========================================
# Cloudflare Tunnel
# ===========================================

# Cloudflare Tunnel Token - for exposing server via cloudflared
# Get this from your Cloudflare Zero Trust dashboard -> Access -> Tunnels
CF_TOKEN=your_cloudflare_tunnel_token_here

# ===========================================
# Development Options (optional)
# ===========================================

# Set to "true" to use mock TTS (no GPU needed)
# USE_MOCK_TTS=true

# Set to "false" to use mock ASR instead of Qwen3-ASR
# USE_QWEN_ASR=false

# Set to "true" to use mock LLM
# USE_MOCK_LLM=false